<div class="p-4">
  <h3 class="text-sm font-semibold text-neutral-900 dark:text-white mb-3">Notes</h3>

  <!-- Note input form -->
  <div id="note_form">
    <%= render "notes/form", project: project %>
  </div>

  <!-- Notes list -->
  <div id="notes_list" class="mt-4 space-y-3">
    <% if project.notes.any? %>
      <% project.notes.each do |note| %>
        <%= turbo_frame_tag dom_id(note) do %>
          <%= render "notes/note", project: project, note: note %>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-xs text-neutral-400 dark:text-neutral-600 italic">No notes yet</p>
    <% end %>
  </div>
</div>
