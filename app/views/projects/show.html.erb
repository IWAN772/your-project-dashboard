<div class="py-10">
  <div class="px-4 sm:px-6 lg:px-8">
    <!-- Back Navigation -->
    <div class="mb-6">
      <%= link_to projects_path, class: "inline-flex items-center gap-2 text-sm text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Projects
      <% end %>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 overflow-hidden sticky top-4">
          <!-- Quick Actions -->
          <div class="p-4 border-b border-neutral-200 dark:border-neutral-700">
            <h3 class="text-sm font-semibold text-neutral-900 dark:text-white mb-3">Quick Actions</h3>
            <div class="space-y-2" data-controller="quick-actions" data-quick-actions-path-value="<%= @project.path %>">
              <button data-action="click->quick-actions#openEditor"
                      class="w-full inline-flex items-center gap-2 px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
                Open in Editor
              </button>
              <button data-action="click->quick-actions#openTerminal"
                      class="w-full inline-flex items-center gap-2 px-3 py-2 bg-neutral-700 dark:bg-neutral-600 text-white text-sm font-medium rounded-lg hover:bg-neutral-800 dark:hover:bg-neutral-700 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                Open Terminal
              </button>
              <% if @project.github_url.present? %>
                <%= link_to @project.github_url, target: "_blank", rel: "noopener noreferrer",
                    class: "w-full inline-flex items-center gap-2 px-3 py-2 bg-neutral-700 dark:bg-neutral-600 text-white text-sm font-medium rounded-lg hover:bg-neutral-800 dark:hover:bg-neutral-700 transition-colors" do %>
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                  </svg>
                  Open in GitHub
                <% end %>
              <% end %>
              <button data-action="click->quick-actions#copyPath"
                      class="w-full inline-flex items-center gap-2 px-3 py-2 bg-white dark:bg-neutral-900 border border-neutral-300 dark:border-neutral-600 text-neutral-700 dark:text-neutral-300 text-sm font-medium rounded-lg hover:bg-neutral-50 dark:hover:bg-neutral-800 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                </svg>
                Copy Path
              </button>
            </div>
          </div>

          <!-- Details -->
          <div class="p-4">
            <h3 class="text-sm font-semibold text-neutral-900 dark:text-white mb-3">Details</h3>
            <dl class="space-y-3 text-sm">
              <div>
                <dt class="text-neutral-500 dark:text-neutral-400">Path</dt>
                <dd class="mt-1 text-neutral-900 dark:text-neutral-100 font-mono text-xs break-all">
                  <%= @project.path %>
                </dd>
              </div>
              <div>
                <dt class="text-neutral-500 dark:text-neutral-400">Type</dt>
                <dd class="mt-1">
                  <%= project_type_badge(@project.project_type) %>
                </dd>
              </div>
              <div>
                <dt class="text-neutral-500 dark:text-neutral-400">Commits (8 months)</dt>
                <dd class="mt-1 text-neutral-900 dark:text-neutral-100 font-semibold">
                  <%= @project.commit_count_8m %>
                </dd>
              </div>
            </dl>
          </div>

          <!-- Tags -->
          <div class="border-t border-neutral-200 dark:border-neutral-700">
            <%= turbo_frame_tag "project_tags" do %>
              <%= render "taggings/list", project: @project %>
            <% end %>
          </div>

          <!-- Notes -->
          <div class="border-t border-neutral-200 dark:border-neutral-700">
            <%= turbo_frame_tag "project_notes" do %>
              <%= render "notes/list", project: @project %>
            <% end %>
          </div>

          <!-- Goals -->
          <div class="border-t border-neutral-200 dark:border-neutral-700">
            <%= turbo_frame_tag "project_goals" do %>
              <%= render "project_goals/list", project: @project %>
            <% end %>
          </div>

          <!-- Navigation -->
          <% if @previous_project || @next_project %>
            <div class="p-4 border-t border-neutral-200 dark:border-neutral-700">
              <h3 class="text-sm font-semibold text-neutral-900 dark:text-white mb-3">Navigation</h3>
              <div class="space-y-2 text-sm">
                <% if @previous_project %>
                  <%= link_to project_path(@previous_project), class: "flex items-center gap-2 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
                    </svg>
                    Previous Project
                  <% end %>
                <% end %>
                <% if @next_project %>
                  <%= link_to project_path(@next_project), class: "flex items-center gap-2 text-neutral-600 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                    Next Project
                  <% end %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </aside>

      <!-- Main Content -->
      <div class="lg:col-span-3 space-y-6">
        <!-- Header -->
        <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-6">
          <div class="flex items-start justify-between gap-4 mb-2">
            <h1 class="text-2xl font-bold text-neutral-900 dark:text-white"><%= @project.name %></h1>
            <%= button_to toggle_pin_project_path(@project), method: :post,
                class: "p-2 rounded-lg hover:bg-neutral-100 dark:hover:bg-neutral-700 transition-colors",
                title: @project.pinned? ? "Unpin project" : "Pin project" do %>
              <% if @project.pinned? %>
                <svg class="w-5 h-5 text-amber-500" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                </svg>
              <% else %>
                <svg class="w-5 h-5 text-neutral-400 hover:text-amber-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                </svg>
              <% end %>
            <% end %>
          </div>
          <div class="flex items-center gap-2 flex-wrap">
            <%= status_badge(@project.status) %>
            <% if @project.is_fork %>
              <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-purple-50 text-purple-700 border border-purple-200 dark:bg-purple-900/20 dark:text-purple-400 dark:border-purple-800">
                Fork
              </span>
            <% end %>
            <span class="text-sm text-neutral-500 dark:text-neutral-400">
              Last commit <%= @project.relative_last_commit_date %>
            </span>
            <% if @project.metadata&.dig("deployment_status")&.include?("likely deployed") %>
              <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200 dark:bg-emerald-900/20 dark:text-emerald-400 dark:border-emerald-800">
                Deployed
              </span>
            <% end %>
          </div>
        </div>

        <!-- Description -->
        <% if @project.description.present? %>
          <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-6">
            <h2 class="text-lg font-semibold text-neutral-900 dark:text-white mb-3">Overview</h2>
            <p class="text-neutral-700 dark:text-neutral-300"><%= @project.description %></p>
          </div>
        <% end %>

        <!-- Tech Stack -->
        <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-6">
          <h2 class="text-lg font-semibold text-neutral-900 dark:text-white mb-3">Tech Stack</h2>
          <% if @project.tech_stack_array.any? %>
            <div class="flex flex-wrap gap-2">
              <%= tech_stack_badges(@project.tech_stack_array) %>
            </div>
          <% else %>
            <p class="text-sm text-neutral-400 dark:text-neutral-600 italic">No tech stack detected</p>
          <% end %>
        </div>

        <!-- Recent Activity -->
        <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-6">
          <h2 class="text-lg font-semibold text-neutral-900 dark:text-white mb-4">
            Recent Activity
            <% if @project.metadata&.dig("recent_commits") %>
              <span class="text-sm text-neutral-500 dark:text-neutral-400 font-normal">
                (<%= @project.metadata["recent_commits"].length %> commits)
              </span>
            <% end %>
          </h2>
          <% if @project.metadata&.dig("recent_commits")&.any? %>
            <div class="space-y-4">
              <% @project.metadata["recent_commits"].each do |commit| %>
                <div class="flex gap-3">
                  <div class="flex-shrink-0 w-2 mt-2">
                    <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                  </div>
                  <div class="flex-1 min-w-0 pb-4 border-l-2 border-neutral-200 dark:border-neutral-700 pl-4 -ml-px last:border-0">
                    <p class="text-sm text-neutral-900 dark:text-neutral-100 font-medium">
                      <%= commit[:message] || commit["message"] %>
                    </p>
                    <p class="text-xs text-neutral-500 dark:text-neutral-400 mt-1">
                      <%= commit[:date] || commit["date"] %>
                    </p>
                  </div>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="text-sm text-neutral-400 dark:text-neutral-600 italic">No recent commit data available</p>
          <% end %>
        </div>

        <!-- Contributors -->
        <% if @project.metadata&.dig("contributors")&.any? %>
          <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-6">
            <h2 class="text-lg font-semibold text-neutral-900 dark:text-white mb-3">Contributors</h2>
            <% if @project.metadata["contributors"].length == 1 %>
              <p class="text-sm text-neutral-600 dark:text-neutral-400">
                Solo project (<%= @project.metadata["contributors"].first %>)
              </p>
            <% else %>
              <ul class="space-y-2">
                <% @project.metadata["contributors"].each do |contributor| %>
                  <li class="text-sm text-neutral-700 dark:text-neutral-300"><%= contributor %></li>
                <% end %>
              </ul>
            <% end %>
          </div>
        <% end %>

        <!-- Reference Files -->
        <% if @project.metadata&.dig("reference_files")&.any? %>
          <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-6">
            <h2 class="text-lg font-semibold text-neutral-900 dark:text-white mb-4">Documentation</h2>
            <div class="space-y-3" data-controller="accordion">
              <% @project.metadata["reference_files"].each do |category, files| %>
                <div class="border border-neutral-200 dark:border-neutral-700 rounded-lg overflow-hidden">
                  <button data-action="click->accordion#toggle"
                          class="w-full flex items-center justify-between px-4 py-2 bg-neutral-50 dark:bg-neutral-900 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors">
                    <span class="text-sm font-medium text-neutral-900 dark:text-neutral-100">
                      <%= category.to_s.capitalize %> (<%= files.length %>)
                    </span>
                    <svg data-accordion-target="icon" class="w-4 h-4 text-neutral-500 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div data-accordion-target="content" class="hidden px-4 py-3 bg-white dark:bg-neutral-800">
                    <ul class="space-y-1.5">
                      <% files.each do |file| %>
                        <li class="text-sm text-neutral-600 dark:text-neutral-400 font-mono">
                          <%= file %>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
