<div class="py-10">
  <div class="px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-neutral-900 dark:text-white">Project Dashboard</h1>
          <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
            <%= pluralize(@projects.total_count, 'project') %> found
            <% if active_filter_count > 0 %>
              (<%= pluralize(active_filter_count, 'filter') %> active)
            <% end %>
          </p>
        </div>
        <div>
          <%= link_to "Scan Projects", "#", class: "inline-flex items-center px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" %>
        </div>
      </div>
    </div>

    <!-- Quick Resume Cards -->
    <% if @recent_projects.any? %>
      <div class="mb-8">
        <!-- Section Header -->
        <div class="flex items-center gap-2 mb-4">
          <svg class="w-5 h-5 text-neutral-500 dark:text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
          <h2 class="text-lg font-semibold text-neutral-900 dark:text-white">Quick Resume</h2>
          <span class="text-sm text-neutral-500 dark:text-neutral-400">(<%= @recent_projects.size %> most recent)</span>
        </div>

        <!-- Cards Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <% @recent_projects.each do |project| %>
            <%= link_to project_path(project),
                class: "block group bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded-lg p-4 hover:border-neutral-400 dark:hover:border-neutral-500 hover:shadow-sm transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2",
                data: { turbo_frame: "_top" } do %>

              <!-- Header -->
              <div class="flex items-start justify-between gap-2 mb-3">
                <h3 class="text-base font-semibold text-neutral-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors truncate">
                  <%= project.name %>
                </h3>
                <div class="flex items-center gap-2">
                  <%= status_badge(project.status) %>
                  <% if project.github_url.present? %>
                    <button type="button"
                            onclick="event.stopPropagation(); window.open('<%= project.github_url %>', '_blank');"
                            class="text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors"
                            title="View on GitHub">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                      </svg>
                    </button>
                  <% end %>
                </div>
              </div>

              <!-- Commit Message -->
              <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-2 line-clamp-2">
                <%= project.last_commit_message %>
              </p>

              <!-- Meta -->
              <div class="flex items-center gap-2 mb-3 text-xs text-neutral-500 dark:text-neutral-400">
                <time datetime="<%= project.last_commit_date %>">
                  <%= project.relative_last_commit_date %>
                </time>
                <% if project.is_fork %>
                  <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400">
                    Fork
                  </span>
                <% end %>
                <% if project.docs_count > 0 %>
                  <span class="inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    <%= project.docs_count %> docs
                  </span>
                <% end %>
              </div>

              <!-- Tech Stack -->
              <% if project.tech_stack_array.any? %>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <% project.tech_stack_array.take(4).each do |tech| %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs bg-neutral-100 text-neutral-600 dark:bg-neutral-700 dark:text-neutral-400">
                      <%= tech_icon(tech) %>
                      <span class="font-medium"><%= tech.capitalize %></span>
                    </span>
                  <% end %>
                  <% if project.tech_stack_array.length > 4 %>
                    <span class="inline-flex items-center px-2 py-0.5 rounded text-xs text-neutral-500 dark:text-neutral-400">
                      +<%= project.tech_stack_array.length - 4 %>
                    </span>
                  <% end %>
                </div>
              <% end %>

              <!-- Goals -->
              <% if project.project_goals.any? %>
                <div class="flex flex-wrap gap-1.5 mb-3">
                  <% project.project_goals.each do |project_goal| %>
                    <%= goal_badge(project_goal.goal.name, project_goal.status) %>
                  <% end %>
                </div>
              <% end %>

              <!-- Recent Note -->
              <% if project.recent_note.present? %>
                <div class="pt-3 border-t border-neutral-100 dark:border-neutral-700">
                  <div class="flex items-start gap-2">
                    <svg class="w-3.5 h-3.5 text-neutral-400 dark:text-neutral-500 mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                    </svg>
                    <p class="text-xs text-neutral-600 dark:text-neutral-400 line-clamp-2 flex-1">
                      <%= project.recent_note.content %>
                    </p>
                  </div>
                </div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- Filter Form (outside Turbo Frame to preserve state) -->
    <%= render "filter_form" %>

    <!-- Active Filters Pills -->
    <% if active_filter_count > 0 %>
      <div class="mb-4 flex items-center gap-2 flex-wrap">
        <span class="text-sm text-neutral-600 dark:text-neutral-400">Active filters:</span>

        <% if params[:search].present? %>
          <%= link_to projects_path(filter_params(exclude: [:search])),
                      data: { turbo_frame: "results" },
                      class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-xs text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
            Search: "<%= params[:search] %>"
            <span aria-hidden="true">×</span>
          <% end %>
        <% end %>

        <% if params[:ownership].present? && params[:ownership] != "all" %>
          <%= link_to projects_path(filter_params(exclude: [:ownership])),
                      data: { turbo_frame: "results" },
                      class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-xs text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
            Ownership: <%= params[:ownership] == "own" ? "My Projects" : "Forks" %>
            <span aria-hidden="true">×</span>
          <% end %>
        <% end %>

        <% if params[:status].present? && params[:status] != "all" %>
          <%= link_to projects_path(filter_params(exclude: [:status])),
                      data: { turbo_frame: "results" },
                      class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-xs text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
            Status: <%= params[:status].capitalize %>
            <span aria-hidden="true">×</span>
          <% end %>
        <% end %>

        <% if params[:tech_stack].present? %>
          <%= link_to projects_path(filter_params(exclude: [:tech_stack])),
                      data: { turbo_frame: "results" },
                      class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-xs text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
            Tech: <%= params[:tech_stack].capitalize %>
            <span aria-hidden="true">×</span>
          <% end %>
        <% end %>

        <% if params[:type].present? && params[:type] != "all" %>
          <%= link_to projects_path(filter_params(exclude: [:type])),
                      data: { turbo_frame: "results" },
                      class: "inline-flex items-center gap-1.5 px-2.5 py-1 bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 rounded text-xs text-neutral-700 dark:text-neutral-300 hover:bg-neutral-50 dark:hover:bg-neutral-700 transition-colors" do %>
            Type: <%= params[:type].split('-').map(&:capitalize).join(' ') %>
            <span aria-hidden="true">×</span>
          <% end %>
        <% end %>

        <%= link_to "Clear all", projects_path,
                    data: { turbo_frame: "results" },
                    class: "text-xs text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 font-medium" %>
      </div>
    <% end %>

    <!-- Results Table (wrapped in Turbo Frame) -->
    <%= turbo_frame_tag "results" do %>
      <%= render "table", projects: @projects %>
    <% end %>
  </div>
</div>
