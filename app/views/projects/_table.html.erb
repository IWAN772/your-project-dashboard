<% if projects.any? %>
  <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full border-collapse" data-controller="clickable-rows">
        <caption class="sr-only">Table of projects. Click project name or row to view details.</caption>
        <thead>
          <tr class="border-b border-neutral-200 dark:border-neutral-700 bg-neutral-50 dark:bg-neutral-900">
            <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-neutral-900 dark:text-white">
              Project
            </th>
            <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-neutral-900 dark:text-white">
              Status
            </th>
            <th scope="col" class="px-4 py-3 text-left text-sm font-semibold text-neutral-900 dark:text-white hidden md:table-cell">
              Last Activity
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-200 dark:divide-neutral-700">
          <% projects.each do |project| %>
            <tr
              class="odd:bg-white even:bg-neutral-50 dark:odd:bg-neutral-900/50 dark:even:bg-neutral-950 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition-colors cursor-pointer group"
              data-clickable-rows-url-value="<%= project_path(project) %>"
              data-action="click->clickable-rows#navigate">

              <!-- Project Name -->
              <td class="px-4 py-3">
                <div class="flex flex-col">
                  <div class="flex items-center gap-2">
                    <%= link_to project.name,
                                project_path(project),
                                class: "font-medium text-neutral-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 hover:underline",
                                data: { turbo_frame: "_top" } %>
                    <% if project.is_fork %>
                      <span class="inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400" title="Forked project">
                        Fork
                      </span>
                    <% end %>
                  </div>
                  <!-- Mobile: Show last activity below name -->
                  <span class="text-xs text-neutral-500 dark:text-neutral-400 mt-0.5 md:hidden">
                    <%= project.relative_last_commit_date %>
                  </span>
                </div>
              </td>

              <!-- Status -->
              <td class="px-4 py-3">
                <%= status_badge(project.status) %>
              </td>

              <!-- Last Activity (hidden on mobile) -->
              <td class="px-4 py-3 hidden md:table-cell">
                <span class="text-sm text-neutral-700 dark:text-neutral-300">
                  <%= project.relative_last_commit_date %>
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <!-- Pagination -->
    <% if projects.total_pages > 1 %>
      <div class="px-4 py-3 border-t border-neutral-200 dark:border-neutral-700">
        <div class="flex items-center justify-between">
          <div class="text-sm text-neutral-700 dark:text-neutral-300">
            Showing <%= projects.offset_value + 1 %>-<%= [projects.offset_value + projects.limit_value, projects.total_count].min %> of <%= projects.total_count %> projects
          </div>
          <div>
            <%= paginate projects, window: 2 %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <!-- Empty state -->
  <div class="bg-white dark:bg-neutral-800 rounded-lg border border-neutral-200 dark:border-neutral-700 p-12">
    <div class="text-center">
      <svg class="mx-auto h-12 w-12 text-neutral-400 dark:text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
      </svg>
      <h3 class="mt-2 text-sm font-medium text-neutral-900 dark:text-white">No projects found</h3>
      <p class="mt-1 text-sm text-neutral-500 dark:text-neutral-400">
        <% if active_filter_count > 0 %>
          Try adjusting your filters or <%= link_to "clear all filters", projects_path, data: { turbo_frame: "results" }, class: "text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300" %>.
        <% else %>
          Run <code class="px-1.5 py-0.5 bg-neutral-100 dark:bg-neutral-900 rounded text-xs font-mono">bin/rake projects:scan</code> to discover your repositories.
        <% end %>
      </p>
    </div>
  </div>
<% end %>
