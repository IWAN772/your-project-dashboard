<div class="flex items-center justify-between gap-2 p-2 bg-neutral-50 dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-700 rounded-lg">
  <div class="flex items-center gap-2 flex-1 min-w-0">
    <span class="text-sm text-neutral-900 dark:text-neutral-100 font-medium truncate">
      <%= project_goal.goal.name.titleize %>
    </span>
    <%= form_with model: [project, project_goal], method: :patch, data: { turbo_frame: dom_id(project_goal) } do |f| %>
      <%= f.select :status,
          ProjectGoal.statuses.keys.map { |s| [s.titleize, s] },
          {},
          class: "text-xs px-2 py-1 rounded border border-neutral-300 dark:border-neutral-600 bg-white dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 focus:outline-none focus:ring-1 focus:ring-blue-500 #{status_color(project_goal.status)}",
          onchange: "this.form.requestSubmit()" %>
    <% end %>
  </div>
  <%= button_to project_project_goal_path(project, project_goal),
      method: :delete,
      form: { data: { turbo_frame: "project_goals", turbo_confirm: "Remove this goal?" } },
      class: "flex-shrink-0 text-neutral-400 hover:text-red-600 dark:hover:text-red-400 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  <% end %>
</div>
